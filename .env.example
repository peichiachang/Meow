# Supabase（必填）
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Edge Function 需在 Supabase Dashboard 設定 Secret：
# ANTHROPIC_API_KEY=your_anthropic_api_key
# CRON_SECRET=your_random_secret  # 僅用於 cleanup-old-messages 排程驗證

# 本地 AI 測試（scripts/test-ai-chat.ts）需在 .env 加入：
# ANTHROPIC_API_KEY=your_anthropic_api_key
