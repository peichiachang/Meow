# Supabase（必填）
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Edge Function 需在 Supabase Dashboard 設定 Secret：
# GEMINI_API_KEY=your_gemini_api_key  # 免費取得 https://aistudio.google.com/apikey
# CRON_SECRET=your_random_secret  # 僅用於 cleanup-old-messages 排程驗證

# 本地 AI 測試（npm run test:ai）需在 .env 加入：
# GEMINI_API_KEY=your_gemini_api_key

# 選填：每日對話次數上限，不設或設為 0 = 不限次數（預設為 20）
VITE_DAILY_MESSAGE_LIMIT=20

# 選填：例外帳號列表（不受訊息限制），以逗號分隔的 user_id
# VITE_EXEMPT_USER_IDS=user_id_1,user_id_2

# 選填：Buy Me a Coffee 用戶名（用於顯示打賞按鈕）
# VITE_BUYMEACOFFEE_USERNAME=your_username
